    <!-- Audio Screen -->
    <string name="audio_screen_title">Better Nothing\nMusic Visualizer</string>
    <string name="audio_description_running">Real time audio visualizer is active. Your phone is now dancing to the beat! No content is saved, and privacy is respected.</string>
    <string name="audio_description_idle">This app was made by Aleks Levet, rKyzen, and Oliver lebaigue.\n\nTo synchronize the Glyph Interface with your music, this app captures device audio. We use Media Projection for high-fidelity visualization.\n\nPrivacy Note: We only utilize the audio stream. No screen content is recorded.</string>
    <string name="audio_warning_vizualizer">Warning: this source uses the standard Android visualizer-style audio stream. It is low fidelity and may suck.</string>
