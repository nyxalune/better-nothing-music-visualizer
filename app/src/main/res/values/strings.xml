    <string name="glyph_debug_title">Nothing Phone (1) on Android 15</string>
    <string name="glyph_debug_desc_adb_enabled">Glyph features need the Nothing glyph debug interface enabled through ADB on this device.</string>
    <string name="glyph_debug_desc_dev_options">Glyph features need Developer options enabled first on Nothing Phone (1) running Android 15. After that, run this ADB command:</string>
    <string name="glyph_debug_command">adb shell settings put global nt_glyph_interface_debug_enable 1</string>
    <string name="glyph_debug_instruction">Run the command once from a computer with ADB, then reopen the app if the Glyphs still do not respond.</string>

    <!-- About Screen -->
    <string name="about_title">App info and updates</string>
    <string name="about_description">WE NEED A DAMN PROPER ABOUT SCREEN!! In the meantime please check GitHub for info.</string>
    <string name="about_intro">Better Nothing Music Visualizer unlocks the full potential of the Glyph Interface with high-fidelity, real-time frequency analysis.</string>
    <string name="about_section_why">Why are we better than Nothing\'s implementation:</string>
    <string name="about_why_1">• 12-bit brightness (4096 levels) vs ~2-bit stock (3 levels)</string>
    <string name="about_why_2">• 60 FPS fluid animations vs ~25 FPS stock</string>
    <string name="about_why_3">• Precise FFT sync vs semi-random response</string>
    <string name="about_why_4">• Independent sub-zone control</string>
