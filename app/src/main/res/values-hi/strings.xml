    <string name="experimental_features">प्रायोगिक विशेषताएं</string>
    <string name="developer_mode">डेवलपर मोड</string>
    <string name="developer_mode_description">उन्नत परीक्षण और डिवाइस स्पूफिंग सुविधाओं को सक्षम करें।</string>
    <string name="spoof_device">स्पूफ डिवाइस</string>
    <string name="spoof_device_description">ऐप को यह व्यवहार करने के लिए मजबूर करता है जैसे कि यह चयनित डिवाइस पर चल रहा हो।</string>
    <string name="idle_breathing_title">आइडल ब्रीदिंग</string>
    <string name="idle_breathing_desc">जब विज़ुअलाइज़र सक्रिय होता है लेकिन कोई ऑडियो नहीं चल रहा होता है तो ग्लिफ़ सूक्ष्म रूप से पल्स करते हैं।</string>
    <string name="notification_flash_title">नोटिफिकेशन फ्लैश</string>
    <string name="notification_flash_desc">विज़ुअलाइज़र चलते समय नया नोटिफिकेशन आने पर सभी ग्लिफ़ को संक्षेप में फ्लैश करता है।</string>
    <string name="disable_glyphs_when_silent_title">शांत होने पर ग्लिफ़ अक्षम करें</string>
    <string name="disable_glyphs_when_silent_desc">जब कोई ऑडियो नहीं मिलता है तो ग्लिफ़ को पूरी तरह से बंद कर दें और सत्र को जारी करें।</string>
    <string name="start_visualizer">प्रारंभ</string>
    <string name="stop_visualizer">रोकें</string>
    <string name="glyph_no_config">कोई कॉन्फ़िगरेशन लोड नहीं हुआ। नवीनतम विज़ुअलाइज़र प्रीसेट डाउनलोड करने के लिए कृपया सेटिंग्स में अपडेट की जांच करें।</string>
    <string name="glyph_debug_title">एंड्रॉइड 15 पर नथिंग फोन (1)</string>
    <string name="glyph_debug_desc_adb_enabled">ग्लिफ सुविधाओं के लिए इस डिवाइस पर ADB के माध्यम से नथिंग ग्लिफ़ डिबग इंटरफ़ेस सक्षम होना आवश्यक है।</string>
    <string name="glyph_debug_desc_dev_options">एंड्रॉइड 15 चलाने वाले नथिंग फोन (1) पर पहले डेवलपर विकल्प सक्षम होने की आवश्यकता है। उसके बाद, यह ADB कमांड चलाएं:</string>
    <string name="glyph_debug_command">adb shell settings put global nt_glyph_interface_debug_enable 1</string>
    <string name="glyph_debug_instruction">ADB वाले कंप्यूटर से एक बार कमांड चलाएँ, फिर ऐप को फिर से खोलें यदि ग्लिफ़ अभी भी प्रतिक्रिया नहीं दे रहे हैं।</string>

    <!-- About Screen -->
    <string name="about_title">ऐप की जानकारी और अपडेट</string>
    <string name="about_description">हमें एक उचित \'अबाउट\' स्क्रीन चाहिए!! इस बीच कृपया जानकारी के लिए GitHub देखें।</string>
    <string name="about_intro">बेटर नथिंग म्यूजिक विज़ुअलाइज़र हाई-फिडेलिटी, रीयल-टाइम फ्रीक्वेंसी विश्लेषण के साथ ग्लिफ इंटरफ़ेस की पूरी क्षमता को अनलॉक करता है।</string>
    <string name="about_section_why">हम नथिंग के कार्यान्वयन से बेहतर क्यों हैं:</string>
    <string name="about_why_1">• 12-बिट चमक (4096 स्तर) बनाम ~2-बिट स्टॉक (3 स्तर)</string>
    <string name="about_why_2">• 60 FPS फ्लूइड एनिमेशन बनाम ~25 FPS स्टॉक</string>
    <string name="about_why_3">• सटीक FFT सिंक बनाम अर्ध-यादृच्छिक प्रतिक्रिया</string>
    <string name="about_why_4">• स्वतंत्र उप-क्षेत्र नियंत्रण</string>
