    <string name="glyph_debug_instruction">Exécutez la commande depuis un ordinateur via ADB, puis relancez l\'application si les Glyphs ne répondent toujours pas.</string>

    <!-- About Screen -->
    <string name="about_title">Infos et mises à jour</string>
    <string name="about_intro">Better Nothing Music Visualizer exploite tout le potentiel de l\'interface Glyph grâce à une analyse fréquentielle haute fidélité en temps réel.</string>
    <string name="about_section_why">Pourquoi nous sommes meilleurs que Nothing :</string>
    <string name="about_why_1">• Luminosité 12 bits (4096 niveaux) vs ~2 bits (3 niveaux)</string>
    <string name="about_why_2">• Animations fluides à 60 FPS vs ~25 FPS</string>
    <string name="about_why_3">• Synchronisation FFT précise vs réponse semi-aléatoire</string>
    <string name="about_why_4">• Contrôle indépendant des sous-zones</string>
