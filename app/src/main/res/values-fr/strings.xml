    <string name="glyph_debug_title">Nothing Phone (1) sur Android 15</string>
    <string name="glyph_debug_desc_adb_enabled">Les fonctionnalités Glyph nécessitent l\'activation de l\'interface de débogage Glyph de Nothing via ADB sur cet appareil.</string>
    <string name="glyph_debug_desc_dev_options">Les fonctionnalités Glyph nécessitent d\'abord l\'activation des options Développeur sur le Nothing Phone (1) sous Android 15. Ensuite, exécutez cette commande ADB :</string>
    <string name="glyph_debug_command">adb shell settings put global nt_glyph_interface_debug_enable 1</string>
    <string name="glyph_debug_instruction">Exécutez la commande une fois depuis un ordinateur avec ADB, puis rouvrez l\'application si les Glyphs ne répondent toujours pas.</string>

    <!-- About Screen -->
    <string name="about_title">Infos et mises à jour de l\'application</string>
    <string name="about_description">NOUS AVONS BESOIN D\'UN VRAI ÉCRAN À PROPOS !! En attendant, veuillez consulter GitHub pour plus d\'informations.</string>
    <string name="about_intro">Better Nothing Music Visualizer libère tout le potentiel de l\'interface Glyph avec une analyse de fréquence haute fidélité en temps réel.</string>
    <string name="about_section_why">Pourquoi sommes-nous meilleurs que l\'implémentation de Nothing :</string>
    <string name="about_why_1">• Luminosité 12 bits (4096 niveaux) vs ~2 bits d\'origine (3 niveaux)</string>
    <string name="about_why_2">• Animations fluides 60 FPS vs ~25 FPS d\'origine</string>
    <string name="about_why_3">• Synchro FFT précise vs réponse semi-aléatoire</string>
    <string name="about_why_4">• Contrôle indépendant des sous-zones</string>
