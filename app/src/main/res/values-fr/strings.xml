    <string name="glyph_debug_desc_adb_enabled">Les fonctionnalités Glyph nécessitent l\'activation du mode débug Glyph de Nothing via ADB sur cet appareil.</string>
    <string name="glyph_debug_desc_dev_options">Activez d\'abord les options développeur sur votre Nothing Phone (1). Ensuite, exécutez cette commande ADB :</string>
