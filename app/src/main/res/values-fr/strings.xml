    <string name="app_name">Better Nothing Music Visualizer</string>

    <!-- Audio Screen -->
    <string name="audio_screen_title">Better Nothing\nMusic Visualizer</string>
    <string name="audio_description_running">Le visualiseur audio en temps réel est actif. Votre téléphone danse désormais au rythme de la musique ! Aucun contenu n\'est enregistré et votre vie privée est respectée.</string>
    <string name="audio_description_idle">Cette application a été créée par Aleks Levet, rKyzen et Oliver Lebaigue.\n\nPour synchroniser l\'interface Glyph avec votre musique, cette application capture le flux audio de l\'appareil via Media Projection pour une visualisation haute fidélité.\n\nNote sur la confidentialité : seul le flux audio est utilisé. Aucun contenu à l\'écran n\'est enregistré.</string>
    <string name="audio_warning_vizualizer">Attention : cette source utilise le flux audio standard du visualiseur Android. La fidélité est moindre et le résultat est dans la plupart des cas merdique.</string>
    <string name="auto_memorize_device">Mémorisation auto de l\'appareil</string>
    <string name="saving_latency_for">Latence enregistrée pour : %s</string>
    <string name="internal_speaker">Haut-parleur interne</string>
    <string name="manual_mode_global_latency">Mode manuel (Latence globale)</string>
    <string name="latency_compensation_description">La compensation de latence assure une synchronisation parfaite des Glyphs avec le rythme, ce qui est particulièrement utile pour les appareils Bluetooth.</string>
    <string name="latency_compensation">Compensation de latence</string>
    <string name="live_spectrum">Spectre audio en direct</string>

