    <string name="app_name">Visualiseur de Musique Better Nothing</string>

    <!-- Audio Screen -->
    <string name="audio_screen_title">Visualiseur de Musique\nBetter Nothing</string>
    <string name="audio_description_running">Le visualiseur audio en temps réel est actif. Votre téléphone danse maintenant au rythme ! Aucun contenu n\'est enregistré, et la vie privée est respectée.</string>
    <string name="audio_description_idle">Cette application a été créée par Aleks Levet, rKyzen et Oliver lebaigue.\n\nPour synchroniser l\'Interface Glyph avec votre musique, cette application capture l\'audio de l\'appareil. Nous utilisons Media Projection pour une visualisation haute fidélité.\n\nNote sur la confidentialité : Nous utilisons uniquement le flux audio. Aucun contenu de l\'écran n\'est enregistré.</string>
    <string name="audio_warning_vizualizer">Avertissement : cette source utilise le flux audio standard du visualiseur Android. Il est de basse fidélité et peut être décevant.</string>
    <string name="auto_memorize_device">Mémorisation automatique de l\'appareil</string>
    <string name="saving_latency_for">Enregistrement de la latence pour : %s</string>
    <string name="internal_speaker">Haut-parleur interne</string>
    <string name="manual_mode_global_latency">Mode manuel (Latence globale)</string>
    <string name="latency_compensation_description">La compensation de latence garantit que les Glyphs frappent exactement sur le rythme, particulièrement utile pour les appareils Bluetooth.</string>
    <string name="latency_compensation">Compensation de latence</string>
    <string name="live_spectrum">Spectre audio en direct</string>

