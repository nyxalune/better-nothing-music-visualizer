    <string name="app_name">Visualizador de Música Better Nothing</string>

    <!-- Audio Screen -->
    <string name="audio_screen_title">Visualizador de Música\nBetter Nothing</string>
    <string name="audio_description_running">O visualizador de áudio em tempo real está ativo. Seu telefone agora está dançando no ritmo! Nenhum conteúdo é salvo e a privacidade é respeitada.</string>
    <string name="audio_description_idle">Este aplicativo foi feito por Aleks Levet, rKyzen e Oliver Lebaigue.\n\nPara sincronizar a Interface Glyph com sua música, este aplicativo captura o áudio do dispositivo. Usamos Media Projection para visualização de alta fidelidade.\n\nNota de Privacidade: Utilizamos apenas o fluxo de áudio. Nenhum conteúdo da tela é gravado.</string>
    <string name="audio_warning_vizualizer">Aviso: esta fonte utiliza o fluxo de áudio padrão do estilo visualizador do Android. É de baixa fidelidade e pode não ser ideal.</string>
    <string name="auto_memorize_device">Memorizar Dispositivo Automaticamente</string>
    <string name="saving_latency_for">Salvando latência para: %s</string>
    <string name="internal_speaker">Alto-falante Interno</string>
    <string name="manual_mode_global_latency">Modo manual (Latência global)</string>
    <string name="latency_compensation_description">A compensação de latência garante que os Glyphs batam exatamente no ritmo, especialmente útil para dispositivos Bluetooth.</string>
    <string name="latency_compensation">Compensação de Latência</string>
    <string name="live_spectrum">Espectro de Áudio ao Vivo</string>

