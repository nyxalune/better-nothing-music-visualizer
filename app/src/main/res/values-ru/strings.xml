    <string name="app_name">Better Nothing Музыкальный визуализатор</string>

    <!-- Audio Screen -->
    <string name="audio_screen_title">Better Nothing\nМузыкальный визуализатор</string>
    <string name="audio_description_running">Аудиовизуализатор в реальном времени активен. Ваш телефон теперь танцует под ритм! Контент не сохраняется, конфиденциальность соблюдается.</string>
    <string name="audio_description_idle">Это приложение было создано Aleks Levet, rKyzen и Oliver Lebaigue.\n\nДля синхронизации интерфейса Glyph с вашей музыкой это приложение захватывает звук устройства. Мы используем Media Projection для высокоточной визуализации.\n\nПримечание о конфиденциальности: мы используем только аудиопоток. Контент экрана не записывается.</string>
    <string name="audio_warning_vizualizer">Предупреждение: этот источник использует стандартный аудиопоток Android в стиле визуализатора. Он имеет низкое качество и может работать неудовлетворительно.</string>
    <string name="auto_memorize_device">Автоматически запоминать устройство</string>
    <string name="saving_latency_for">Сохранение задержки для: %s</string>
    <string name="internal_speaker">Внутренний динамик</string>
    <string name="manual_mode_global_latency">Ручной режим (глобальная задержка)</string>
    <string name="latency_compensation_description">Компенсация задержки гарантирует, что глифы будут срабатывать точно в такт, что особенно полезно для Bluetooth-устройств.</string>
    <string name="latency_compensation">Компенсация задержки</string>
    <string name="live_spectrum">Живой аудиоспектр</string>

