    <string name="app_name">Visualizador de Música Better Nothing</string>

    <!-- Audio Screen -->
    <string name="audio_screen_title">Visualizador de Música\nBetter Nothing</string>
    <string name="audio_description_running">El visualizador de audio en tiempo real está activo. ¡Tu teléfono ahora baila al ritmo! No se guarda ningún contenido y se respeta la privacidad.</string>
    <string name="audio_description_idle">Esta aplicación fue creada por Aleks Levet, rKyzen y Oliver lebaigue.\n\nPara sincronizar la interfaz Glyph con tu música, esta aplicación captura el audio del dispositivo. Usamos Media Projection para una visualización de alta fidelidad.\n\nNota de privacidad: Solo utilizamos el flujo de audio. No se graba el contenido de la pantalla.</string>
    <string name="audio_warning_vizualizer">Advertencia: esta fuente utiliza el flujo de audio estándar de Android estilo visualizador. Es de baja fidelidad y puede no ser óptimo.</string>
    <string name="auto_memorize_device">Recordar dispositivo automáticamente</string>
    <string name="saving_latency_for">Guardando latencia para: %s</string>
    <string name="internal_speaker">Altavoz interno</string>
    <string name="manual_mode_global_latency">Modo manual (Latencia global)</string>
    <string name="latency_compensation_description">La compensación de latencia asegura que los Glyphs coincidan exactamente con el ritmo, especialmente útil para dispositivos Bluetooth.</string>
    <string name="latency_compensation">Compensación de latencia</string>
    <string name="live_spectrum">Espectro de audio en vivo</string>

