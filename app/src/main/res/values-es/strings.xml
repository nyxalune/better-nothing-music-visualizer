    <string name="glyph_debug_title">Nothing Phone (1) en Android 15</string>
    <string name="glyph_debug_desc_adb_enabled">Las funciones de Glyph necesitan que la interfaz de depuración de Glyph de Nothing esté habilitada a través de ADB en este dispositivo.</string>
    <string name="glyph_debug_desc_dev_options">Las funciones de Glyph necesitan que las opciones de Desarrollador estén habilitadas primero en el Nothing Phone (1) con Android 15. Después de eso, ejecuta este comando ADB:</string>
    <string name="glyph_debug_command">adb shell settings put global nt_glyph_interface_debug_enable 1</string>
    <string name="glyph_debug_instruction">Ejecuta el comando una vez desde un ordenador con ADB, luego vuelve a abrir la aplicación si los Glyphs aún no responden.</string>

    <!-- About Screen -->
    <string name="about_title">Información de la aplicación y actualizaciones</string>
    <string name="about_description">¡¡NECESITAMOS UNA PANTALLA DE INFORMACIÓN ADECUADA!! Mientras tanto, consulta GitHub para obtener información.</string>
    <string name="about_intro">Better Nothing Music Visualizer desbloquea todo el potencial de la interfaz Glyph con un análisis de frecuencia en tiempo real y alta fidelidad.</string>
    <string name="about_section_why">Por qué somos mejores que la implementación de Nothing:</string>
    <string name="about_why_1">• Brillo de 12 bits (4096 niveles) vs ~2 bits de serie (3 niveles)</string>
    <string name="about_why_2">• Animaciones fluidas a 60 FPS vs ~25 FPS de serie</string>
    <string name="about_why_3">• Sincronización FFT precisa vs respuesta semi-aleatoria</string>
    <string name="about_why_4">• Control independiente de subzonas</string>
