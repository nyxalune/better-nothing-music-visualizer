<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Source Row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SOURCE"
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_source_internal"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_button_bg"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Internal Source" />

        <ImageButton
            android:id="@+id/btn_source_mic"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/widget_button_bg"
            android:src="@drawable/ic_play"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Mic Source" />

        <ImageButton
            android:id="@+id/btn_source_viz"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_button_bg"
            android:src="@drawable/ic_nav_glyphs"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Visualizer Source" />
    </LinearLayout>

    <!-- Output Row -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OUTPUT"
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_viz_haptics"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_button_bg"
            android:src="@drawable/ic_vibration"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Toggle Haptics" />

        <ImageButton
            android:id="@+id/btn_viz_glyphs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/widget_button_bg"
            android:src="@drawable/ic_nav_glyphs"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Toggle Glyphs" />

        <ImageButton
            android:id="@+id/btn_viz_torch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_button_bg"
            android:src="@drawable/ic_stop"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="Toggle Torch" />
    </LinearLayout>

    <!-- Start/Stop Button -->
    <ImageButton
        android:id="@+id/btn_start_stop"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_button_bg"
        android:src="@drawable/ic_play"
        android:scaleType="centerInside"
        android:contentDescription="Start/Stop Visualizer" />

</LinearLayout>
