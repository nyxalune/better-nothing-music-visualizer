    <!-- Audio Screen -->
    <string name="audio_screen_title">Visualizzatore Musicale\nBetter Nothing</string>
    <string name="audio_description_running">Il visualizzatore audio in tempo reale è attivo. Il tuo telefono ora balla al ritmo! Nessun contenuto viene salvato e la privacy è rispettata.</string>
    <string name="audio_description_idle">Questa app è stata creata da Aleks Levet, rKyzen e Oliver Lebaigue.\n\nPer sincronizzare l\'interfaccia Glyph con la tua musica, questa app cattura l\'audio del dispositivo. Utilizziamo Media Projection per una visualizzazione ad alta fedeltà.\n\nNota sulla privacy: utilizziamo solo il flusso audio. Nessun contenuto dello schermo viene registrato.</string>
    <string name="audio_warning_vizualizer">Attenzione: questa sorgente utilizza il flusso audio standard dello stile visualizzatore Android. È a bassa fedeltà e potrebbe non essere ottimale.</string>
    <string name="auto_memorize_device">Memorizza dispositivo automaticamente</string>
    <string name="saving_latency_for">Salvataggio latenza per: %s</string>
    <string name="internal_speaker">Altoparlante interno</string>
    <string name="manual_mode_global_latency">Modalità manuale (Latenza globale)</string>
    <string name="latency_compensation_description">La compensazione della latenza assicura che i Glyph vadano esattamente a ritmo, particolarmente utile per i dispositivi Bluetooth.</string>
    <string name="latency_compensation">Compensazione latenza</string>
    <string name="live_spectrum">Spettro audio dal vivo</string>

