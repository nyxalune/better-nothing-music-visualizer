<resources>
    <string name="app_name">Better Nothing 音乐可视化工具</string>

    <!-- Audio Screen -->
    <string name="audio_screen_title">Better Nothing\n音乐可视化工具</string>
    <string name="audio_description_running">实时音频可视化工具已激活。您的手机正随节奏舞动！不保存任何内容，尊重隐私。</string>
    <string name="audio_description_idle">此应用由 Aleks Levet、rKyzen 和 Oliver Lebaigue 开发。\n\n为了使 Glyph 界面与您的音乐同步，此应用会捕捉设备音频。我们使用媒体投影进行高保真可视化。\n\n隐私提示：我们仅利用音频流。不记录任何屏幕内容。</string>
    <string name="audio_warning_vizualizer">警告：此来源使用标准的 Android 可视化器样式音频流。它是低保真的，效果可能不佳。</string>
    <string name="auto_memorize_device">自动记忆设备</string>
    <string name="saving_latency_for">正在保存延迟： %s</string>
    <string name="internal_speaker">内置扬声器</string>
    <string name="manual_mode_global_latency">手动模式（全局延迟）</string>
    <string name="latency_compensation_description">延迟补偿可确保 Glyph 准确命中节拍，对于蓝牙设备尤其有用。</string>
    <string name="latency_compensation">延迟补偿</string>
    <string name="live_spectrum">实时音频频谱</string>

    <!-- Glyph Screen -->
    <string name="glyph_controls">Glyph 控制</string>
    <string name="gamma_control">伽马控制</string>
    <string name="gamma_description">较高的伽马值会带来更有力的视觉效果，但细节较少且整体亮度较低。较低的伽马值更亮但力度较弱。</string>
    <string name="light_gamma">光线伽马：</string>
    <string name="visualizer_presets">可视化器预设</string>

