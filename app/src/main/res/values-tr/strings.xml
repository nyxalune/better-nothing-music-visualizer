    <string name="manual_mode_global_latency">Manuel mod (Genel gecikme)</string>
    <string name="latency_compensation_description">Gecikme telafisi, özellikle Bluetooth cihazları için kullanışlıdır ve Gliflerin tam olarak ritme göre yanmasını sağlar.</string>
